# Supabase Settings
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<supabase-anon-jwt>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-jwt>
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# External Signals APIs
OPENWEATHER_API_KEY=
CPCB_API_KEY=

# Payment Integrations (Razorpay Sandbox)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Notifications (Firebase)
ENABLE_PUSH_NOTIFICATIONS=false
FIREBASE_CREDENTIALS_PATH=backend/firebase-credentials.json
FIREBASE_CREDENTIALS_JSON=

# AI Chat Assistant
OPENROUTER_API_KEY=
GROQ_API_KEY=
GROQ_MODEL_NAME=qwen/qwen3-32b
OPENROUTER_MODEL_NAME=google/gemma-3-27b-it
OPENROUTER_HTTP_REFERER=https://gighood.app
OPENROUTER_APP_TITLE=gigHood Gig Copilot

# Neo4j Fraud Graph
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=<instance-id>
NEO4J_PASSWORD=<neo4j-password>
# For Aura with named DB, set the instance DB name. Leave blank to use Neo4j default DB.
NEO4J_DATABASE=

# ML (Risk Profiler)
RISK_PROFILER_MODEL_JSON_PATH=backend/ml/risk_profiler.json
RISK_PROFILER_MODEL_PKL_PATH=backend/ml/risk_profiler.pkl
RISK_PROFILER_DATASET_PATH=dataset/synthetic_training_data.csv
AUTO_TRAIN_RISK_MODEL_ON_STARTUP=true

# Security
JWT_SECRET=<generate-strong-random-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated frontend origins)
BACKEND_CORS_ORIGINS=http://localhost:3000,https://gighood.vercel.app

# Scheduler reliability
ENABLE_SCHEDULER=false
SIGNAL_JOB_CRON_MINUTE=*/10
DCI_JOB_CRON_MINUTE=1,11,21,31,41,51
SCHEDULER_MAX_INSTANCES=1
SCHEDULER_COALESCE=true
SCHEDULER_MISFIRE_GRACE_SECONDS=300
SCHEDULER_HEX_LIMIT=150
SCHEDULER_ROTATE_HEX_BATCH=true
SIGNAL_INGESTION_HEX_SLEEP_SECONDS=0.02
DCI_CYCLE_HEX_SLEEP_SECONDS=0.01

# Supabase network retry for transient disconnections
SUPABASE_RETRY_ATTEMPTS=5
SUPABASE_RETRY_BACKOFF_SECONDS=0.5
